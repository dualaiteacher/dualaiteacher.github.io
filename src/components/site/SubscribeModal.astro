<div
  class="consent-backdrop bg-brand/80 backdrop-blur-md"
  id="subscribeBackdrop"
  data-visible="false"
  aria-hidden="true"
>
</div>
<div
  class="consent-modal bg-white rounded-2xl shadow-2xl overflow-hidden border-2 border-accent"
  id="subscribeModal"
  data-visible="false"
  role="dialog"
  aria-modal="true"
  aria-labelledby="subscribeTitle"
>
  <div class="bg-brand px-6 py-6 text-white relative">
    <button
      onclick="closeSubscribeModal()"
      class="absolute top-4 right-4 text-white hover:text-accent transition-colors cursor-pointer bg-transparent border-0"
      aria-label="Close"
     
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2.5"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>
    <h2
      id="subscribeTitle"
      class="text-2xl font-black flex items-center gap-2 m-0 text-accent"
     
    >
      Stay Updated
    </h2>
    <p class="text-sm text-blue-100 mt-2 mb-0 leading-relaxed font-medium">
      Follow the DUAL.AI.TEACHer project to get the latest news, deliverables,
      and exclusive training opportunities directly in your inbox.
    </p>
  </div>
  <form id="subscribeForm" class="px-6 py-8 flex flex-col gap-5 bg-slate-50">
    <div>
      <label
        for="emailInput"
        class="block text-sm font-black text-brand uppercase tracking-wider mb-2"
       
        >Email Address</label
      >
      <input
        type="email"
        id="emailInput"
        required
        placeholder="you@example.com"
       
        class="w-full px-4 py-3 rounded-xl border-2 border-slate-300 focus:border-brand focus:ring-4 focus:ring-brand/20 outline-none transition-all text-slate-700 font-medium bg-white shadow-inner"
      />
    </div>
    <button
      type="submit"
      class="w-full px-6 py-4 mt-2 rounded-xl text-lg font-black uppercase tracking-wide bg-accent text-slate-600 shadow-lg shadow-accent/50 hover:bg-accent-hover transition-all cursor-pointer border-0"
     
    >
      Follow the Project
    </button>
  </form>
</div>

