<script is:inline>
  (function () {
    "use strict";
  })();

  (function () {
    var menuBtn = document.getElementById("mobileMenuBtn");
    var menu = document.getElementById("mobileMenu");
    if (menuBtn && menu) {
      menuBtn.addEventListener("click", function () {
        menu.classList.toggle("hidden");
      });

      menu.querySelectorAll("a").forEach(function (link) {
        link.addEventListener("click", function () {
          menu.classList.add("hidden");
        });
      });
    }
  })();

  document.addEventListener("DOMContentLoaded", function () {
    var counters = document.querySelectorAll(".counter");

    var numberObserver = new IntersectionObserver(
      function (entries, observer) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var target = Number(entry.target.getAttribute("data-target"));
            var count = 0;
            var duration = 2000;
            var frameRate = 30;
            var increment = target / (duration / frameRate);

            var updateCount = function () {
              if (count < target) {
                count += increment;
                entry.target.innerText = Math.ceil(count).toLocaleString();
                setTimeout(updateCount, frameRate);
              } else {
                entry.target.innerText = target.toLocaleString();
              }
            };

            updateCount();
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 },
    );

    counters.forEach(function (counter) {
      numberObserver.observe(counter);
    });
  });

  (function () {
    "use strict";

    var STORAGE_KEY = "clarity_consent_v2";
    var CONSENT_EXPIRY_DAYS = 365;

    var banner = document.getElementById("consentBanner");
    var backdrop = document.getElementById("consentBackdrop");
    var modal = document.getElementById("consentModal");
    var acceptAllBtn = document.getElementById("acceptAllBtn");
    var rejectAllBtn = document.getElementById("rejectAllBtn");
    var openPrefsLink = document.getElementById("openPrefsLink");
    var analyticsToggle = document.getElementById("analyticsToggle");
    var adToggle = document.getElementById("adToggle");
    var cancelPrefsBtn = document.getElementById("cancelPrefsBtn");
    var rejectAllPrefs = document.getElementById("rejectAllPrefsBtn");
    var savePrefsBtn = document.getElementById("savePrefsBtn");

    if (
      !banner ||
      !backdrop ||
      !modal ||
      !acceptAllBtn ||
      !rejectAllBtn ||
      !openPrefsLink ||
      !analyticsToggle ||
      !adToggle ||
      !cancelPrefsBtn ||
      !rejectAllPrefs ||
      !savePrefsBtn
    ) {
      return;
    }

    function safeParse(json) {
      try {
        return JSON.parse(json);
      } catch (e) {
        return null;
      }
    }

    function deleteCookie(name) {
      var encoded = encodeURIComponent(name);
      document.cookie = encoded + "=; Max-Age=0; Path=/; SameSite=Lax";
      var parts = location.hostname.split(".");
      if (parts.length >= 2) {
        var baseDomain = parts.slice(-2).join(".");
        document.cookie =
          encoded +
          "=; Max-Age=0; Path=/; Domain=." +
          baseDomain +
          "; SameSite=Lax";
      }
    }

    function eraseClarityCookies() {
      deleteCookie("_clck");
      deleteCookie("_clsk");
    }

    function saveConsent(consent) {
      localStorage.setItem(
        STORAGE_KEY,
        JSON.stringify({
          ad_Storage: consent.ad_Storage,
          analytics_Storage: consent.analytics_Storage,
          timestamp: Date.now(),
        }),
      );
    }

    function loadConsent() {
      var raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      var parsed = safeParse(raw);
      if (!parsed || !parsed.ad_Storage || !parsed.analytics_Storage)
        return null;
      if (parsed.timestamp) {
        var age = Date.now() - parsed.timestamp;
        if (age > CONSENT_EXPIRY_DAYS * 24 * 60 * 60 * 1000) {
          localStorage.removeItem(STORAGE_KEY);
          return null;
        }
      }
      return {
        ad_Storage: parsed.ad_Storage,
        analytics_Storage: parsed.analytics_Storage,
      };
    }

    function applyClarityConsent(consent) {
      if (!consent) return;
      if (typeof window.clarity === "function") {
        window.clarity("consentv2", {
          ad_Storage: consent.ad_Storage,
          analytics_Storage: consent.analytics_Storage,
        });
      }
      if (
        consent.ad_Storage === "denied" &&
        consent.analytics_Storage === "denied"
      ) {
        eraseClarityCookies();
      }
    }

    function showBanner() {
      banner.setAttribute("data-visible", "true");
    }

    function hideBanner() {
      banner.removeAttribute("data-visible");
    }

    function openModal() {
      backdrop.setAttribute("data-visible", "true");
      backdrop.setAttribute("aria-hidden", "false");
      modal.setAttribute("data-visible", "true");
      savePrefsBtn.focus();
    }

    function closeModal() {
      modal.removeAttribute("data-visible");
      backdrop.removeAttribute("data-visible");
      backdrop.setAttribute("aria-hidden", "true");
    }

    function syncToggles(consent) {
      analyticsToggle.checked = consent.analytics_Storage === "granted";
      adToggle.checked = consent.ad_Storage === "granted";
    }

    function applyAndClose(consent) {
      saveConsent(consent);
      applyClarityConsent(consent);
      closeModal();
      hideBanner();
    }

    var existing = loadConsent();
    if (existing) {
      applyClarityConsent(existing);
    } else {
      showBanner();
    }

    acceptAllBtn.addEventListener("click", function () {
      applyAndClose({ ad_Storage: "granted", analytics_Storage: "granted" });
    });

    rejectAllBtn.addEventListener("click", function () {
      applyAndClose({ ad_Storage: "denied", analytics_Storage: "denied" });
    });

    openPrefsLink.addEventListener("click", function (e) {
      e.preventDefault();
      var current = loadConsent() || {
        ad_Storage: "denied",
        analytics_Storage: "denied",
      };
      syncToggles(current);
      openModal();
    });

    backdrop.addEventListener("click", closeModal);
    cancelPrefsBtn.addEventListener("click", closeModal);

    rejectAllPrefs.addEventListener("click", function () {
      applyAndClose({ ad_Storage: "denied", analytics_Storage: "denied" });
    });

    savePrefsBtn.addEventListener("click", function () {
      applyAndClose({
        analytics_Storage: analyticsToggle.checked ? "granted" : "denied",
        ad_Storage: adToggle.checked ? "granted" : "denied",
      });
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && modal.getAttribute("data-visible") === "true") {
        closeModal();
      }
    });

    window.openCookieSettings = function () {
      var current = loadConsent() || {
        ad_Storage: "denied",
        analytics_Storage: "denied",
      };
      syncToggles(current);
      showBanner();
      openModal();
    };
  })();

